# Copy this file to ".env" in the same folder (never commit .env).
# Use your real API base URL including /api/v1
#
# Until you have a custom domain (e.g. api.honeymoon.ae), use your deployed API, e.g. Vercel:
# EXPO_PUBLIC_API_URL=https://honeymoon-app-api.vercel.app/api/v1
#
# Local API on your PC (Android emulator: use http://10.0.2.2:5000/api/v1)
# EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1

EXPO_PUBLIC_API_URL=https://YOUR-API-HOST.vercel.app/api/v1
